{
  "name": "zoorl-infrastructure",
  "version": "0.1.0",
  "bin": {
    "zoorl-infrastructure": "bin/zoorl-infrastructure.js"
  },
  "scripts": {
    "format": "prettier --write .",
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "cdk:synth": "npm run build && cdk synth",
    "cdk:deploy": "npm run build && cdk deploy",
    "cdk:destroy": "npm run build && cdk destroy",
    "cdk:diff": "npm run build && cdk diff"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/node": "22.7.5",
    "@types/prettier": "3.0.0",
    "aws-cdk": "2.161.1",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "pretty-quick": "^4.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3"
  },
  "dependencies": {
    "@aws-cdk/aws-lambda-python-alpha": "^2.161.1-alpha.0",
    "aws-cdk-lib": "2.161.1",
    "aws-sdk": "^2.1691.0",
    "constructs": "^10.3.0",
    "source-map-support": "^0.5.21"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged"
    }
  }
}
